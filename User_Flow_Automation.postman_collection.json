    {
      "name": "Login (extract token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the JSON response",
              "const jsonData = pm.response.json();",
              "",
              "// Extract the token and store it in the environment variable",
              "pm.environment.set(\"token\", jsonData.token);",
              "",
              "//display to console",
              "console.log('token value is; ', pm.environment.get(\"token\"));",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Get the current timestamp",
              "const now = new Date();",
              "",
              "// Helper function to add leading zeros",
              "const padZero = (num) => num.toString().padStart(2, '0');",
              "",
              "// Extract date components",
              "const month = padZero(now.getMonth() + 1); // Months are 0-indexed",
              "const day = padZero(now.getDate());",
              "const year = now.getFullYear();",
              "const hours = padZero(now.getHours());",
              "const minutes = padZero(now.getMinutes());",
              "const seconds = padZero(now.getSeconds());",
              "",
              "// Format as mm-DD-yyyy HH:mm:ss",
              "const formattedTimestamp = `${month}-${day}-${year} ${hours}:${minutes}:${seconds}`;",
              "",
              "// Store in environment variable",
              "pm.environment.set(\"time now\", formattedTimestamp);",
              "",
              "console.log(\"Formatted timestamp:\", formattedTimestamp);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "x-api-key",
            "value": "reqres_b24f2b35a9164e739f4b0d138cebb6b7",
            "type": "text"
          }
        ],
        "body": {
